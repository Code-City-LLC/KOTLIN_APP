# Copy this file to keystore.properties and fill it with the existing,
# Play-authorized upload key details. keystore.properties and key files are
# ignored by Git; never commit their real values.
storeFile=/absolute/path/to/play-upload-key.jks
storePassword=replace-with-secure-value
keyAlias=replace-with-upload-alias
keyPassword=replace-with-secure-value
